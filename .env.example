# Feature toggles
LIVE_OBSERVATIONS_ENABLED=true
LIVE_FORECASTS_ENABLED=true
REFRESH_INTERVAL_SECONDS=600
REQUEST_TIMEOUT_SECONDS=8

# KNMI
KNMI_API_KEY=
KNMI_API_BASE_URL=https://api.dataplatform.knmi.nl/open-data/v1
KNMI_DATASET_NAME=10-minute-in-situ-meteorological-observations
KNMI_DATASET_VERSION=1.0

# Meteo-France
METEOFRANCE_OBSERVATION_URL=
METEOFRANCE_API_KEY=

# NOAA / NCEI ISD
NCEI_API_BASE_URL=https://www.ncei.noaa.gov/access/services/data/v1
NCEI_DATASET=global-hourly
NCEI_TOKEN=

# Forecast source (Open-Meteo)
OPENMETEO_API_BASE_URL=https://api.open-meteo.com/v1/forecast
OPENMETEO_MODEL_HARMONIE=knmi_harmonie_arome_netherlands
OPENMETEO_MODEL_AROME=meteofrance_arome_france_hd
OPENMETEO_MODEL_ICON=icon_eu
OPENMETEO_MODEL_ECMWF=ecmwf_ifs04
